{
    "section-blur": {
        "type": "section",
        "description": "Blur"
    },
    "backgd-blur-menus": {
      "type": "switch",
      "default": true,
      "description": "Popup menus"
    },
    "backgd-blur-notifications": {
      "type": "switch",
      "default": true,
      "description": "Notifications"
    },
    "backgd-blur-strength": {
        "type": "scale",
        "default": 6,
        "min": 1,
        "max": 24,
        "step": 1,
        "description": "Blur strength"
    },
    "surface-style": {
        "type": "combobox",
        "default": "Simple blur",
        "description": "Surface style",
        "options": {
            "Simple blur": "disabled",
            "Glass pane": "pane",
            "Tempered glass": "tempered"
        }
    }
}
